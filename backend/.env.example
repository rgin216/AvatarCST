PORT=5000
MONGO_URI=
NODE_ENV=development
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=marin

# Rhubarb Lip Sync binary path (download from https://github.com/DanielSWolf/rhubarb-lip-sync/releases)
# Example (Windows): RHUBARB_PATH=C:/tools/rhubarb/rhubarb.exe
# Example (macOS/Linux): RHUBARB_PATH=/usr/local/bin/rhubarb
# Leave empty to use placeholder visemes (lip-sync disabled)
RHUBARB_PATH=

# Groq (free API — runs Whisper STT + LLaMA LLM in the cloud, no local install needed)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Pipeline mode — controls the end-to-end audio processing pipeline:
#   free     → Groq Whisper (STT) → Groq LLaMA (LLM) → edge-tts (TTS) → Rhubarb   [no cost]
#   realtime → OpenAI Realtime mini (STT + LLM + TTS combined)                       [token cost]
PIPELINE_MODE=free

# TTS voice for edge-tts (used when PIPELINE_MODE=free)
# NZ voices: en-NZ-MitchellNeural (male), en-NZ-MollyNeural (female)
# Full list: https://learn.microsoft.com/azure/ai-services/speech-service/language-support
TTS_VOICE=en-NZ-MitchellNeural
